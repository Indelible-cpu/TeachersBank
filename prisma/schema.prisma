generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Settings {
  id                    String   @id @default(uuid())
  organizationName      String   @default("Teachers Bank Management System")
  systemName            String   @default("TEBAMS")
  logo                  String?
  receiptFooter         String?
  contactDetails        String?
  defaultLanguage       String   @default("en")
  interestPercentage    Float    @default(0)
  emergencyInterestPercentage Float @default(0)
  maturityMonths        Int      @default(12)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(MEMBER)
  isActive  Boolean  @default(true)
  currentChallenge String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  member    Member?
  auditLogs AuditLog[]
  authenticators Authenticator[]
}

model Authenticator {
  id                   String  @id @default(uuid())
  credentialID         Bytes   @unique
  credentialPublicKey  Bytes
  counter              BigInt
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  
  userId               String
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  TREASURER
  SECRETARY
  MEMBER
}

model Member {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  memberNumber    String   @unique
  fullname        String
  alternativeNames String?  
  phone           String?
  phone2          String?  
  gender          String?  
  address         String?
  photo           String?
  joinDate        DateTime @default(now())
  
  shareContributions     ShareContribution[]
  emergencyContributions EmergencyContribution[]
  loans                  Loan[]
  repayments             Repayment[]
  disbursements          Disbursement[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  userRole        String
  action          String
  details         String?  
  startTime       DateTime @default(now())
  endTime         DateTime?
  status          String   @default("SUCCESS") 
  ipAddress       String?
  
  createdAt       DateTime @default(now())
}

model ContributionCycle {
  id             String   @id @default(uuid())
  name           String   
  startDate      DateTime
  endDate        DateTime
  maturityMonths Int
  isActive       Boolean  @default(true)
  
  shareContributions     ShareContribution[]
  emergencyContributions EmergencyContribution[]
  disbursements          Disbursement[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ConfirmationStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum FundType {
  SHARE
  EMERGENCY
}

model ShareContribution {
  id              String   @id @default(uuid())
  memberId        String
  member          Member   @relation(fields: [memberId], references: [id])
  contributorName String?  
  cycleId         String
  cycle           ContributionCycle @relation(fields: [cycleId], references: [id])
  amount          Float
  month           Int      
  year            Int      
  isAdvance       Boolean  @default(false)
  recordedBy      String   
  
  // Treasurer Confirmation
  status          ConfirmationStatus @default(PENDING)
  confirmedBy     String?  // Treasurer ID
  confirmedAt     DateTime?
  
  receiptId       String?  @unique
  receipt         Receipt? @relation(fields: [receiptId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmergencyContribution {
  id              String   @id @default(uuid())
  memberId        String
  member          Member   @relation(fields: [memberId], references: [id])
  contributorName String?  
  cycleId         String
  cycle           ContributionCycle @relation(fields: [cycleId], references: [id])
  amount          Float
  month           Int
  year            Int
  isAdvance       Boolean  @default(false)
  recordedBy      String
 
  // Treasurer Confirmation
  status          ConfirmationStatus @default(PENDING)
  confirmedBy     String?  // Treasurer ID
  confirmedAt     DateTime?

  receiptId       String?  @unique
  receipt         Receipt? @relation(fields: [receiptId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Loan {
  id             String   @id @default(uuid())
  memberId       String
  member         Member   @relation(fields: [memberId], references: [id])
  principal      Float
  interestRate   Float
  expectedReturn Float
  balance        Float
  status         LoanStatus @default(PENDING)
  fundType       FundType   @default(SHARE)
  dueDate        DateTime
  recordedBy     String
  
  shareInterest  Float?
  memberShares   Float?
  confirmedBy    String?
  confirmedAt    DateTime?
  
  repayments     Repayment[]
  receipts       Receipt[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LoanStatus {
  PENDING
  VERIFIED
  APPROVED
  REJECTED
  FULLY_PAID
}

model Repayment {
  id         String   @id @default(uuid())
  loanId     String
  loan       Loan     @relation(fields: [loanId], references: [id])
  memberId   String
  member     Member   @relation(fields: [memberId], references: [id])
  amount     Float
  recordedBy String

  // Treasurer Confirmation
  status          ConfirmationStatus @default(PENDING)
  confirmedBy     String?  // Treasurer ID
  confirmedAt     DateTime?

  receiptId  String?  @unique
  receipt    Receipt? @relation(fields: [receiptId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Disbursement {
  id         String   @id @default(uuid())
  memberId   String
  member     Member   @relation(fields: [memberId], references: [id])
  cycleId    String
  cycle      ContributionCycle @relation(fields: [cycleId], references: [id])
  amount     Float
  interest   Float
  fundType   FundType   @default(SHARE)
  status     DisbursementStatus @default(PENDING)
  recordedBy String
  receiptId  String?  @unique
  receipt    Receipt? @relation(fields: [receiptId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DisbursementStatus {
  PENDING
  MATURED
  DISBURSED
}

model Receipt {
  id              String   @id @default(uuid())
  receiptNumber   String   @unique
  memberId        String?
  amount          Float
  transactionType String   
  transactionDate DateTime @default(now())
  details         String?  
  receiptUrl      String?  
  
  shareContribution      ShareContribution?
  emergencyContribution  EmergencyContribution?
  repayment              Repayment?
  disbursement           Disbursement?
  loan                   Loan?    @relation(fields: [loanId], references: [id])
  loanId                 String?
  
  createdAt DateTime @default(now())
}

