{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "lib": ["es2022", "dom"],
    "typeRoots": ["./node_modules/@types"],
    "types": ["node", "express", "jsonwebtoken", "bcryptjs", "multer", "cors"]
  },
  "include": ["api/**/*", "prisma/**/*", "backend/src/**/*"],
  "exclude": ["node_modules", "frontend"]
}
